<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>Dreamora | Pro 2D Studio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&display=swap');
        body { background: #020617; color: white; font-family: 'Plus Jakarta Sans', sans-serif; overflow: hidden; margin: 0; }
        .glass { background: rgba(15, 23, 42, 0.8); backdrop-filter: blur(25px); border: 1px solid rgba(255, 255, 255, 0.1); }
        
        /* Layout */
        .main-grid { display: grid; grid-template-columns: 1fr 400px; height: calc(100vh - 80px); }
        
        /* Item Selection */
        .item-card { cursor: pointer; transition: 0.2s; border: 2px solid transparent; background: rgba(255,255,255,0.03); border-radius: 20px; display: flex; align-items: center; justify-content: center; height: 70px; font-weight: 800; font-size: 10px; text-transform: uppercase; text-align: center; padding: 5px; }
        .item-card.active { border-color: #3b82f6; background: rgba(59, 130, 246, 0.1); color: #3b82f6; }
        
        /* Color Swatches */
        .color-swatch { width: 32px; height: 32px; border-radius: 50%; cursor: pointer; border: 2px solid rgba(255,255,255,0.1); transition: 0.2s; }
        .color-swatch:hover { transform: scale(1.2); border-color: white; }
        .color-swatch.active { border-color: #3b82f6; transform: scale(1.1); box-shadow: 0 0 15px rgba(59,130,246,0.5); }

        /* Icons */
        .cat-btn { font-size: 22px; opacity: 0.4; transition: 0.3s; padding: 15px; border-radius: 20px; }
        .cat-btn.active { opacity: 1; background: rgba(59, 130, 246, 0.15); color: #3b82f6; }

        /* SVG Rendering */
        #char-svg { filter: drop-shadow(0 25px 50px rgba(0,0,0,0.7)); height: 85%; transition: 0.3s; }
        .hidden { display: none !important; }
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
    </style>
</head>
<body>

    <!-- HEADER -->
    <header class="h-20 px-8 flex justify-between items-center z-50 border-b border-white/5">
        <button onclick="location.href='index.html'" class="glass px-6 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-white/5 transition">Zurück</button>
        <div class="text-xl font-black italic tracking-tighter">AVATAR<span class="text-blue-500">STUDIO</span></div>
        <button id="saveBtn" class="bg-blue-600 hover:bg-blue-500 text-white px-8 py-3 rounded-2xl font-black uppercase text-xs shadow-2xl transition-all active:scale-95">Speichern</button>
    </header>

    <div class="main-grid">
        
        <!-- PREVIEW (Links) -->
        <div class="relative flex items-center justify-center bg-gradient-to-b from-slate-900/50 to-transparent p-10">
            <svg id="char-svg" viewBox="0 0 200 500" xmlns="http://www.w3.org/2000/svg">
                <!-- Körper Basis -->
                <path id="skin-body" d="M75,180 Q100,170 125,180 L125,330 Q100,340 75,330 Z" fill="#ffdbac"/>
                <circle id="skin-head" cx="100" cy="130" r="42" fill="#ffdbac"/>
                
                <!-- Arme -->
                <rect id="arm-l" x="55" y="185" width="18" height="120" rx="9" fill="#ffdbac" />
                <rect id="arm-r" x="127" y="185" width="18" height="120" rx="9" fill="#ffdbac" />

                <!-- Beine (Nackt-Basis für Shorts) -->
                <rect id="base-leg-l" x="78" y="330" width="20" height="140" fill="#ffdbac" />
                <rect id="base-leg-r" x="102" y="330" width="20" height="140" fill="#ffdbac" />

                <!-- KLEIDUNG: HOSE (Wird durch Pfade ersetzt) -->
                <path id="mesh-bottom" d="" fill="#808080"/>

                <!-- KLEIDUNG: OBERTEIL -->
                <path id="mesh-top" d="" fill="#111111"/>
                
                <!-- ACCESSOIRES -->
                <g id="mesh-access"></g>

                <!-- GESICHT -->
                <g id="mesh-face">
                    <circle cx="88" cy="125" r="2.5" fill="#000" opacity="0.8"/>
                    <circle cx="112" cy="125" r="2.5" fill="#000" opacity="0.8"/>
                    <path d="M92,148 Q100,154 108,148" stroke="#000" fill="none" stroke-width="1.5" opacity="0.5"/>
                </g>

                <!-- HAARE -->
                <path id="mesh-hair" d="" fill="#222"/>
            </svg>

            <!-- Color Palette Overlay -->
            <div class="absolute bottom-10 glass p-4 rounded-[2rem] flex flex-col gap-4 border-white/10">
                <p class="text-[9px] font-black uppercase text-center opacity-40 tracking-widest">Farbauswahl</p>
                <div id="colorPalette" class="grid grid-cols-6 gap-2">
                    <!-- Swatches -->
                </div>
            </div>
        </div>

        <!-- CONTROLS (Rechts) -->
        <aside class="glass border-l border-white/5 flex flex-col overflow-hidden">
            <!-- Kategorien -->
            <div class="flex justify-around p-4 border-b border-white/5 bg-white/5">
                <button onclick="setTab('hair')" class="cat-btn active" id="tab-hair">💇</button>
                <button onclick="setTab('top')" class="cat-btn" id="tab-top">👕</button>
                <button onclick="setTab('bottom')" class="cat-btn" id="tab-bottom">👖</button>
                <button onclick="setTab('access')" class="cat-btn" id="tab-access">🕶️</button>
                <button onclick="setTab('skin')" class="cat-btn" id="tab-skin">👤</button>
            </div>

            <!-- Items Grid -->
            <div class="flex-grow overflow-y-auto p-6">
                <h3 id="catTitle" class="text-[10px] font-black uppercase text-slate-500 mb-6 tracking-[0.2em]">Frisuren</h3>
                <div id="itemGrid" class="grid grid-cols-2 gap-4">
                    <!-- Dynamisch -->
                </div>
            </div>
        </aside>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getAuth } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";
        import { getFirestore, doc, setDoc } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyD-UJZGKUGRJW-8VywkoZLxd5QNUQNB1fw",
            authDomain: "dreamora-e379a.firebaseapp.com",
            projectId: "dreamora-e379a",
            storageBucket: "dreamora-e379a.appspot.com",
            messagingSenderId: "1016342666502",
            appId: "1:1016342666502:web:8410d27cc926916f0e1287"
        };
        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);

        const $ = (id) => document.getElementById(id);

        // --- DATEN & MODELLE ---
        let current = {
            hair: 0, top: 0, bottom: 0, access: 0, skin: 0,
            hairCol: '#222222', topCol: '#111111', bottomCol: '#808080', accessCol: '#ffffff', skinCol: '#ffdbac'
        };

        const colors = [
            '#000000', '#FFFFFF', '#808080', '#3b82f6', '#ef4444', '#10b981', 
            '#f59e0b', '#ec4899', '#8b5cf6', '#d2b48c', '#4b3621', '#ffdbac'
        ];

        const shapes = {
            hair: [
                "M65,110 Q100,60 135,110 Z", // Kurz
                "M55,135 Q55,70 100,70 Q145,70 145,135 L140,140 Q100,120 60,140 Z", // Bowl
                "M100,80 L115,105 L85,105 Z", // Spiky
                "M55,120 Q55,40 145,40 V150", // Side Long
                "M60,80 H140 V120 Q100,100 60,120 Z", // Flat top
                "M80,80 Q100,30 120,80 V130 H80 Z", // Mohawk
                "M50,110 Q100,10 150,110 L140,150 Q100,130 60,150 Z", // Messy
                "M100,60 A40,40 0 1,1 99,60 Z", // Afro
                "M55,60 Q100,40 145,60 L150,120 H50 Z", // Cap Style
                "M60,100 Q100,85 140,100 L130,180 H70 Z" // Rockstar
            ],
            top: [
                "M75,180 H125 V330 H75 Z", // T-Shirt Basic
                "M70,180 H130 V335 H70 Z M50,185 H70 V250 H50 Z M130,185 H150 V250 H130 Z", // Shirt Sleeves
                "M65,175 H135 V340 H65 Z M45,185 H65 V320 H45 Z M135,185 H155 V320 H135 Z", // Oversize Hoodie
                "M82,180 H118 V330 H82 Z", // Tank Top
                "M75,180 H125 V260 H75 Z", // Crop Top
                "M70,175 Q100,165 130,175 V340 H70 Z", // Sweater
                "M65,170 H135 V350 H65 Z", // Long Coat
                "M75,180 L125,180 L115,330 L85,330 Z", // V-Neck
                "M70,180 H130 V330 L100,350 L70,330 Z", // Edge Shirt
                "M60,180 H140 V300 Q100,320 60,300 Z" // Poncho Style
            ],
            bottom: [
                "M78,330 H98 V470 H78 Z M102,330 H122 V470 H102 Z", // Straight Pants
                "M78,330 Q65,400 78,475 H98 Q110,400 98,330 Z M102,330 Q90,400 102,475 H122 Q135,400 122,330 Z", // BAGGY WAVY (Gewellt)
                "M78,330 H98 V390 H78 Z M102,330 H122 V390 H102 Z", // Summer Shorts
                "M78,330 H100 V430 H78 Z M100,330 H122 V430 H100 Z", // Cargo Shorts
                "M75,330 H125 V410 Q100,430 75,410 Z", // Skirt / Kilt
                "M78,330 L70,470 H98 V330 Z M102,330 L130,470 H102 V330 Z", // Flare Pants
                "M81,330 H95 V470 H81 Z M105,330 H119 V470 H105 Z", // Skinny Jeans
                "M78,330 H98 V440 H78 Z M102,330 H122 V440 H102 Z", // 7/8 Pants
                "M75,330 Q90,470 98,470 V330 Z M125,330 Q110,470 102,470 V330 Z", // Tapered Jogger
                "M78,330 Q70,350 78,400 H98 V330 Z M102,330 Q110,350 102,400 H122 V330 Z" // Boxers
            ],
            access: [
                "", // None
                "<rect x='82' y='122' width='14' height='10' rx='2' stroke='#000'/><rect x='104' y='122' width='14' height='10' rx='2' stroke='#000'/><path d='M96,127 H104' stroke='#000'/>", // Glasses
                "<circle cx='100' cy='130' r='45' fill='none' stroke='gold' stroke-width='1'/>", // Aura
                "<path d='M90,175 Q100,195 110,175' stroke='silver' stroke-width='2'/>", // Chain
                "<rect x='70' y='100' width='60' height='5' fill='red'/>" // Headband
            ],
            skin: ["#ffdbac", "#f1c27d", "#e0ac69", "#8d5524", "#c68642", "#2d1d12", "#ffffff", "#fef3c7", "#4ade80", "#3b82f6"]
        };

        // --- ENGINE ---
        window.setTab = (t) => {
            document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
            $(`tab-${t}`).classList.add('active');
            $('catTitle').innerText = t === 'access' ? 'Accessoires' : t === 'skin' ? 'Hautton' : t.toUpperCase();

            const grid = $('itemGrid'); grid.innerHTML = '';
            const count = shapes[t] ? shapes[t].length : 10;

            for(let i=0; i<count; i++) {
                const card = document.createElement('div');
                card.className = `item-card ${current[t] === i ? 'active' : ''}`;
                card.innerText = `${t} ${i+1}`;
                card.onclick = () => { current[t] = i; updatePreview(); setTab(t); };
                grid.appendChild(card);
            }
            renderColors(t);
        };

        function renderColors(t) {
            const container = $('colorPalette');
            container.innerHTML = '';
            colors.forEach(c => {
                const dot = document.createElement('div');
                dot.className = `color-swatch ${current[t+'Col'] === c ? 'active' : ''}`;
                dot.style.background = c;
                dot.onclick = () => { current[t+'Col'] = c; updatePreview(); renderColors(t); };
                container.appendChild(dot);
            });
        }

        function updatePreview() {
            $('mesh-hair').setAttribute('d', shapes.hair[current.hair]);
            $('mesh-hair').setAttribute('fill', current.hairCol);
            
            $('mesh-top').setAttribute('d', shapes.top[current.top]);
            $('mesh-top').setAttribute('fill', current.topCol);
            
            $('mesh-bottom').setAttribute('d', shapes.bottom[current.bottom]);
            $('mesh-bottom').setAttribute('fill', current.bottomCol);

            $('mesh-access').innerHTML = shapes.access[current.access] || '';
            
            const skin = shapes.skin[current.skin] || current.skinCol;
            $('skin-head').setAttribute('fill', skin);
            $('skin-body').setAttribute('fill', skin);
            $('arm-l').setAttribute('fill', skin);
            $('arm-r').setAttribute('fill', skin);
            $('base-leg-l').setAttribute('fill', skin);
            $('base-leg-r').setAttribute('fill', skin);
        }

        // SAVE
        $('saveBtn').onclick = async () => {
            const svgData = new XMLSerializer().serializeToString($('char-svg'));
            const base64 = "data:image/svg+xml;base64," + btoa(svgData);
            if(auth.currentUser) {
                await setDoc(doc(db, "users", auth.currentUser.uid), { avatar2d: base64 }, { merge: true });
                location.href = "index.html";
            }
        };

        setTab('hair');
        updatePreview();
    </script>
</body>
</html>